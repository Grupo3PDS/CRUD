{
	"info": {
		"name": "ZooFantastico - Pruebas de Criaturas",
		"description": "Colección de pruebas para las operaciones CRUD de Criaturas del API ZooFantastico.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. POST Crear una criatura",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Creature created successfully\", function () {",
							"    pm.response.to.have.status(201);",
							"    const jsonData = pm.response.json();",
							"    pm.expect(jsonData.name).to.eql(\"Dragón\");",
							"    pm.environment.set(\"creatureId\", jsonData.id);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"name\": \"Dragón\",\n  \"species\": \"Draco Vulgaris\",\n  \"size\": 12.5,\n  \"dangerLevel\": 8,\n  \"healthStatus\": \"Healthy\",\n  \"zone\": {\n    \"id\": 1\n  }\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/creatures",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"creatures"
					]
				}
			}
		},
		{
			"name": "2. GET Obtener la lista de criaturas",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Creatures list retrieved successfully\", function () {",
							"    pm.response.to.have.status(200);",
							"    const jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.be.an(\"array\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/creatures",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"creatures"
					]
				}
			}
		},
		{
			"name": "3. GET Obtener una criatura por ID",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Creature retrieved successfully\", function () {",
							"    pm.response.to.have.status(200);",
							"    const jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property(\"id\");",
							"    pm.expect(jsonData.name).to.eql(\"Dragón\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/creatures/{{creatureId}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"creatures",
						"{{creatureId}}"
					]
				}
			}
		},
		{
			"name": "4. PUT Actualizar una criatura",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Creature updated successfully\", function () {",
							"    pm.response.to.have.status(200);",
							"    const jsonData = pm.response.json();",
							"    pm.expect(jsonData.size).to.eql(15.0);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"name\": \"Dragón\",\n  \"species\": \"Draco Vulgaris\",\n  \"size\": 15.0,\n  \"dangerLevel\": 9,\n  \"healthStatus\": \"Healthy\",\n  \"zone\": {\n    \"id\": 1\n  }\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/creatures/{{creatureId}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"creatures",
						"{{creatureId}}"
					]
				}
			}
		},
		{
			"name": "5. DELETE Eliminar una criatura (verificando que no esté en estado crítico)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Creature deleted successfully (Not critical)\", function () {",
							"    pm.response.to.have.status(204);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/creatures/{{creatureId}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"creatures",
						"{{creatureId}}"
					]
				}
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080/api",
			"type": "string"
		}
	]
}
